# MB Intelligence — variaveis de ambiente da API (copie para .env e preencha).
# Em producao/staging, configure no painel da Vercel.

# --- Seguranca ---
# Trava o CORS no dominio do app. Em producao, NAO deixe "*".
MBI_CORS_ORIGIN=https://mb-intelligence.vercel.app

# --- Supabase (obrigatorias) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DOCUMENTS_BUCKET=mb-documents

# --- Observabilidade (opcional; owner-action) ---
# Instale @sentry/node, inicialize e exponha em global.__mbiSentry para o
# logError() do backend encaminhar as falhas 500.
# SENTRY_DSN=

# --- Testes de isolamento de tenant (SOMENTE staging; nunca producao) ---
# Sem estas variaveis a suite tests/integration e PULADA (nao falha).
# MBI_TEST_API_URL=https://staging-mb-intelligence.vercel.app
# MBI_TEST_TOKEN_CLIENT_A=
# MBI_TEST_CLIENT_ID_B=
