# ── MB Intelligence — Variáveis de Ambiente ─────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no GitHub

# Porta do servidor (Railway define automaticamente via PORT)
PORT=3333

# Supabase — Projeto de PRODUÇÃO
# Pegue em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Banco de dados Supabase (conexão direta PostgreSQL)
SUPABASE_DB_HOST=db.SEU-PROJETO.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=SUA_SENHA_AQUI

# Storage
SUPABASE_DOCUMENTS_BUCKET=mb-documents

# Driver de armazenamento: "supabase" (produção) ou "json" (local)
MBI_STORAGE_DRIVER=supabase

# CORS — domínio do frontend em produção
# Exemplo: https://app.mbempresas.com.br
MBI_CORS_ORIGIN=https://SEU-DOMINIO.com.br

# Caminho para os arquivos do frontend (dentro do container)
MBI_WEB_DIR=/app/web

# Arquivo de banco JSON (usado apenas se MBI_STORAGE_DRIVER=json)
MBI_DATA_FILE=./data/db.json
